# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Xcode (if ever opened there)
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/

# Build outputs & signing artifacts (regenerated by scripts/package-app.sh)
out/
build/
dist/
*.app
*.dSYM

# Dev/test scripts stay local; the two BUILD scripts are versioned so CI (and any machine) can
# reproduce the signed .app — see .github/workflows/build.yml. Anchored to macOS/scripts (a bare
# `scripts/*` has a mid-pattern slash → it would anchor to computer-use/scripts, which doesn't exist).
macOS/scripts/*
!macOS/scripts/package-app.sh
!macOS/scripts/make-signing-cert.sh

# Windows helper — same policy: source + CMake/vcpkg manifest are versioned; dev/test
# scripts stay local (the PowerShell BUILD scripts get versioned when P5 lands them).
windows/test/
windows/scripts/*
!windows/scripts/package-app.ps1
!windows/scripts/make-signing-cert.ps1

# macOS cruft
.DS_Store
